# GitHub Linguist
#
# Count maintained implementations, not repository plumbing. These attributes
# keep GitHub's language bar representative of the actual language comparison:
# implementation source is detectable, while manifests, locks, docs, fixtures,
# generated files, and tool configuration stay out of the language totals.
*.md linguist-documentation=true linguist-detectable=false
LICENSE linguist-documentation=true linguist-detectable=false
AGENTS.md linguist-documentation=true linguist-detectable=false
README.md linguist-documentation=true linguist-detectable=false
fixtures/** linguist-detectable=false
scripts/** linguist-detectable=false

.config/** linguist-detectable=false
.config/mise/mise.lock linguist-generated=true linguist-detectable=false
.clang-format linguist-detectable=false
.clang-tidy linguist-detectable=false
.editorconfig linguist-detectable=false
.gitattributes linguist-detectable=false
.gitignore linguist-detectable=false
.luacheckrc linguist-detectable=false
CMakeLists.txt linguist-detectable=false
CMakePresets.json linguist-detectable=false

build/** linguist-generated=true linguist-detectable=false
dist/** linguist-generated=true linguist-detectable=false
out/** linguist-generated=true linguist-detectable=false
coverage/** linguist-generated=true linguist-detectable=false
**/bin/** linguist-generated=true linguist-detectable=false
**/obj/** linguist-generated=true linguist-detectable=false
php/bin/wordcount -linguist-generated -linguist-detectable linguist-language=PHP
lua/bin/** -linguist-generated -linguist-detectable

javascript/node_modules/** linguist-vendored=true linguist-detectable=false
php/vendor/** linguist-vendored=true linguist-detectable=false
elixir/deps/** linguist-vendored=true linguist-detectable=false

*.lock linguist-generated=true linguist-detectable=false
