# GitHub Linguist
#
# Keep the language bar focused on benchmark implementations. Root plumbing is
# excluded, generated and vendored mass stays hidden, and small language-scoped
# manifests count only when they clarify an implementation instead of padding it.
*.md linguist-documentation=true
LICENSE linguist-documentation=true
AGENTS.md linguist-documentation=true
README.md linguist-documentation=true
fixtures/** linguist-documentation=true
scripts/** linguist-detectable=false

.config/** linguist-detectable=false
.clang-format linguist-detectable=false
.clang-tidy linguist-detectable=false
.editorconfig linguist-detectable=false
.gitattributes linguist-detectable=false
.gitignore linguist-detectable=false
.luacheckrc linguist-detectable=false
CMakeLists.txt linguist-detectable=false
CMakePresets.json linguist-detectable=false

build/** linguist-generated=true
dist/** linguist-generated=true
out/** linguist-generated=true
coverage/** linguist-generated=true
rust/target/** linguist-generated=true
go/bin/** linguist-generated=true
csharp/**/bin/** linguist-generated=true
csharp/**/obj/** linguist-generated=true
kotlin/build/** linguist-generated=true
kotlin/.gradle/** linguist-generated=true
kotlin/.kotlin/** linguist-generated=true
elixir/_build/** linguist-generated=true
elixir/word_count linguist-generated=true
haskell/dist-newstyle/** linguist-generated=true
.zig-cache/** linguist-generated=true
zig-out/** linguist-generated=true

javascript/node_modules/** linguist-vendored=true
php/vendor/** linguist-vendored=true
elixir/deps/** linguist-vendored=true
.lua_modules/** linguist-vendored=true
.lua_modules54/** linguist-vendored=true

*.lock linguist-generated=true
go/go.sum linguist-generated=true
kotlin/gradle.lockfile linguist-generated=true
kotlin/gradle/** linguist-generated=true

go/go.mod linguist-language=Go
